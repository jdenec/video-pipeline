# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Redis (default works for local Docker Redis, or your own install)
REDIS_URL=redis://localhost:6379

# Folders — defaults to ~/Videos/pipeline-watch and ~/Videos/pipeline-output
WATCH_FOLDER=~/Videos/pipeline-watch
OUTPUT_FOLDER=~/Videos/pipeline-output

# Whisper model size: base, small, medium, large-v3
WHISPER_MODEL=base

# YouTube (Google Cloud OAuth 2.0)
YOUTUBE_CLIENT_SECRET=client_secret.json

# X / Twitter (Developer Portal)
X_API_KEY=your-api-key
X_API_SECRET=your-api-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_SECRET=your-access-secret

# Threads (Meta Graph API)
THREADS_ACCESS_TOKEN=your-threads-token